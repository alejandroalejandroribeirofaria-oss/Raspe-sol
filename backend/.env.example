# Wallet that receives all payments. Never hardcode this in source files.
TREASURY_WALLET=BFxAnfdAreXaKEvdeG4xQ7zbxE129ex2bimSc8cDnLhZ

# Solana RPC endpoint. Use a paid provider (Helius, QuickNode, Triton) in production —
# the public RPC rate-limits hard and will drop verification requests under load.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_CLUSTER=mainnet-beta

# 'confirmed' is fine for local dev. Use 'finalized' once real money is
# involved so a cluster re-org can never invalidate a payment already granted.
SOLANA_COMMITMENT=confirmed

# Price of a single ticket, in SOL.
TICKET_PRICE_SOL=0.01

# How long an order stays reserved before it expires and the ticket is released again.
ORDER_EXPIRY_MINUTES=5

# Reject any on-chain transaction older than this when used as payment proof.
MAX_TRANSACTION_AGE_SECONDS=900

# Hard ceiling on tickets grantable from a single purchase (abuse / resource protection).
MAX_TICKETS_PER_PURCHASE=1000

# If true, a payment larger than the requested quantity's price grants as
# many tickets as it can afford (floor division — never a partial ticket).
# If false, any amount other than the exact expected price is rejected.
ALLOW_OVERPAYMENT=true

# Documents that remainders never produce partial tickets (this is always
# true in practice — floor() has no other behavior — kept as an explicit flag
# for auditability).
IGNORE_REMAINDER=true

# When true, tickets are only ever granted after successful on-chain
# verification. Keep this true in production; a false value exists only for
# local UI iteration without a funded wallet.
REQUIRE_CHAIN_CONFIRMATION=true

# Ticket lot lifecycle. When the active lot's remaining stock drops to
# LOT_LOW_WATERMARK, a new lot of LOT_SIZE tickets is created automatically.
# AUTO_CREATE_THRESHOLD is accepted as an alias for LOT_LOW_WATERMARK —
# either name works, they mean the same setting.
LOT_SIZE=20000
LOT_LOW_WATERMARK=1000
# AUTO_CREATE_THRESHOLD=1000

# The exact prize mix (30x 0.02 SOL, 1x 1 SOL, 1x 2 SOL, 1x 5 SOL per lot)
# isn't an env var on purpose — it's the PRIZES constant in config.js, right
# next to LOT_SIZE/TICKET_PRICE_SOL, so all of it is reviewed together
# rather than silently overridable at deploy time.

# Required to access GET /api/admin/dashboard (sent as the x-admin-token header).
# Leave unset to keep the admin API disabled.
ADMIN_TOKEN=change-me-to-a-long-random-value

# --- Global chat ------------------------------------------------------
# Every message (and its image, if any) is hard-deleted this long after it
# was sent — there is no permanent history.
CHAT_MESSAGE_TTL_MINUTES=60
CHAT_MAX_MESSAGE_LENGTH=200
CHAT_MIN_MESSAGE_INTERVAL_MS=1000
CHAT_MAX_IMAGES_PER_MINUTE=3
CHAT_MAX_IMAGE_BYTES=5242880
# A message is auto-hidden once it collects this many distinct-wallet reports.
CHAT_REPORT_THRESHOLD=5
# Newly-connected clients only ever receive this many of the most recent
# still-active messages — never "all history."
CHAT_HISTORY_LIMIT=200
CHAT_UPLOAD_DIR=./uploads/chat
# Optional, comma-separated, case-insensitive substrings to block outright.
CHAT_BANNED_WORDS=

# Express server port.
PORT=4000

# Comma-separated list of origins allowed to call this API.
CORS_ORIGIN=http://localhost:5173

# SQLite file location.
DB_PATH=./data/raspesol.db
